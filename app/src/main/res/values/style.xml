<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="EdTextStyle">
        <item name="android:layout_width">300dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:gravity">left</item>
        <item name="android:layout_marginTop">20dp</item>
    </style>

    <style name="DayCicrleSelector">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">@drawable/day_circle_selector</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
    </style>

    <style name="Widget.BottomNavigationView.White"
        parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/light_grey</item>
        <item name="itemActiveIndicatorStyle">@null</item>
    </style>
</resources>